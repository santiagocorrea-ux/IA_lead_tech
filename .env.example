# Copy this file to .env and fill in your values. Never commit .env.

# ---------------------------------------------------------------------------
# Jira
# ---------------------------------------------------------------------------
JIRA_SITE=https://leadtech.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_jira_api_token

# ---------------------------------------------------------------------------
# Bitbucket
# ---------------------------------------------------------------------------
BITBUCKET_USERNAME=your-bitbucket-username
BITBUCKET_TOKEN=your_bitbucket_app_password
BITBUCKET_WORKSPACE=grupoblidoo
BITBUCKET_REPO=visas-public

# ---------------------------------------------------------------------------
# Xray Cloud (test repository)
# Get keys at: Jira → Apps → Xray → API Keys → Create
# ---------------------------------------------------------------------------
XRAY_CLIENT_ID=your_xray_client_id
XRAY_CLIENT_SECRET=your_xray_client_secret

# ---------------------------------------------------------------------------
# Browser automation (Playwright)
# ---------------------------------------------------------------------------
CHROME_PROFILE_DIR=/Users/YOUR_USER/pw-debug-profile
